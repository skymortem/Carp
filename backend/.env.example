# === StarLine API credentials ===
# Get these at https://my.starline.ru (section "Разработчикам", set language to Russian)
STARLINE_APP_ID=
STARLINE_APP_SECRET=
STARLINE_LOGIN=
STARLINE_PASSWORD=

# === JWT secret ===
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-secret-in-production

# === Database ===
# Default: SQLite (file: carp.db in the working directory)
# For Postgres: postgresql+asyncpg://user:pass@localhost:5432/carp
DATABASE_URL=sqlite+aiosqlite:///./carp.db